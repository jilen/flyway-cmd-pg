#!/usr/bin/env bash
set -e

# Flyway command runner with common configuration
# Usage: scripts/run-flyway-cmd [flyway-args...] command

# Default configuration
URL="${URL:-jdbc:postgresql://localhost:5432/flyway_test}"
DB_USER="${DB_USER:-flyway}"
DB_PASSWORD="${DB_PASSWORD:-flyway}"
LOCATIONS="${LOCATIONS:-filesystem:./test-migrations}"

# Use dist binary if FLYWAY_DIST is set, otherwise run via mill
if [ -n "$FLYWAY_DIST" ]; then
    exec "$FLYWAY_DIST" \
        -url="$URL" \
        -user="$DB_USER" \
        -password="$DB_PASSWORD" \
        -locations="$LOCATIONS" \
        "$@"
else
    exec ./mill --no-server commandline.run \
        -url="$URL" \
        -user="$DB_USER" \
        -password="$DB_PASSWORD" \
        -locations="$LOCATIONS" \
        "$@"
fi
